# ==================================================
# 项目根目录 .gitignore - Spring Boot + React(Vite) + Python
# ==================================================

# ------------------------------
# 通用 / 系统无关文件
# ------------------------------
.DS_Store                # macOS 系统文件
Thumbs.db               # Windows 系统文件
*.tmp                   # 临时文件
*.bak                   # 备份文件
*.log                   # 日志文件 (通用)

# ------------------------------
# 后端 - Spring Boot / Maven
# ------------------------------
# Maven 编译输出目录 (对应 backend/target)
target/

# Java 可执行包
*.jar
*.war
*.ear

# Maven 相关缓存
*.lastUpdated
maven-wrapper.jar

# ------------------------------
# 前端 - React / Vite
# ------------------------------
# Node.js 依赖
frontend/node_modules/

# Vite/React 打包构建目录
frontend/dist/
frontend/build/
frontend/out/

# 环境变量文件 (包含敏感密钥)
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.production.local
frontend/.env.test.local

# 前端缓存与日志
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.pnp
frontend/.pnp.js

# 测试覆盖率与编辑器缓存
frontend/coverage/
frontend/.eslintcache
frontend/.cache/

# 备份目录 (不再使用)
frontend/react-backup/

# ------------------------------
# Python - blog-ai-assistant
# ------------------------------
# 虚拟环境目录
blog-ai-assistant/.venv/

# 环境变量 (包含 API Key 等敏感信息)
blog-ai-assistant/.env
blog-ai-assistant/.env.*.local

# Python 字节码缓存
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Python 构建产物
*.egg-info/
*.egg
dist/
build/

# AI 助手运行时数据
blog-ai-assistant/memory.db

# ------------------------------
# IDE 开发工具配置 (全局忽略)
# ------------------------------
# IntelliJ IDEA / WebStorm
.idea/
*.iws
*.iml
*.ipr

# VS Code
.vscode/
!.vscode/extensions.json

# Eclipse
.project
.classpath
.settings/

# ------------------------------
# Claude CLI / Code 配置 (本地，不提交)
# ------------------------------
.claude/

# ------------------------------
# 环境变量 (根目录级别)
# ------------------------------
.env
.env.local
.env.*.local

docs/

# 后端环境配置 (含密钥，不上传)
backend/blog-core/src/main/resources/application-dev.yml
backend/blog-core/src/main/resources/application-prod.yml
