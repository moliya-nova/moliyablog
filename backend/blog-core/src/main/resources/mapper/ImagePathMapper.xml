<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bloger.backend.mapper.ImagePathMapper">
    <resultMap id="ImagePathResult" type="com.bloger.backend.entity.ImagePath">
        <id column="id" property="id"/>
        <result column="directory_id" property="directoryId"/>
        <result column="cos_key" property="cosKey"/>
        <result column="filename" property="filename"/>
        <result column="size" property="size"/>
        <result column="cdn_url" property="cdnUrl"/>
        <result column="uploader_id" property="uploaderId"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="selectById" resultMap="ImagePathResult">
        SELECT * FROM image_path WHERE id = #{id}
    </select>

    <select id="selectByDirectoryId" resultMap="ImagePathResult">
        SELECT * FROM image_path WHERE directory_id = #{directoryId} ORDER BY id DESC LIMIT #{offset}, #{limit}
    </select>

    <select id="countByDirectoryId" resultType="long">
        SELECT COUNT(*) FROM image_path WHERE directory_id = #{directoryId}
    </select>

    <select id="selectByCosKey" resultMap="ImagePathResult">
        SELECT * FROM image_path WHERE cos_key = #{cosKey}
    </select>

    <insert id="insert" parameterType="com.bloger.backend.entity.ImagePath" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO image_path (directory_id, cos_key, filename, size, cdn_url, uploader_id, create_time)
        VALUES (#{directoryId}, #{cosKey}, #{filename}, #{size}, #{cdnUrl}, #{uploaderId}, NOW())
    </insert>

    <update id="updateById" parameterType="com.bloger.backend.entity.ImagePath">
        UPDATE image_path
        SET directory_id = #{directoryId}, cos_key = #{cosKey}, filename = #{filename},
            size = #{size}, cdn_url = #{cdnUrl}, uploader_id = #{uploaderId}
        WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM image_path WHERE id = #{id}
    </delete>

    <delete id="deleteByDirectoryId">
        DELETE FROM image_path WHERE directory_id = #{directoryId}
    </delete>
</mapper>