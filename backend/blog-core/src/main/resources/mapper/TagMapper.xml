<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bloger.backend.mapper.TagMapper">
    <resultMap id="TagResult" type="com.bloger.backend.entity.Tag">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="sort" property="sort"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectById" resultMap="TagResult">
        SELECT * FROM tag WHERE id = #{id}
    </select>

    <select id="selectList" resultMap="TagResult">
        SELECT * FROM tag ORDER BY sort ASC
    </select>

    <select id="selectByArticleId" resultMap="TagResult">
        SELECT t.*
        FROM tag t
        JOIN article_tag at ON t.id = at.tag_id
        WHERE at.article_id = #{articleId}
    </select>

    <select id="searchByName" resultMap="TagResult">
        SELECT * FROM tag WHERE name LIKE CONCAT('%', #{name}, '%') ORDER BY sort ASC
    </select>

    <select id="selectMaxSort" resultType="java.lang.Integer">
        SELECT MAX(sort) FROM tag
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(*) FROM tag
    </select>

    <insert id="insert" parameterType="com.bloger.backend.entity.Tag" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tag (name, description, sort, create_time, update_time)
        VALUES (#{name}, #{description}, #{sort}, NOW(), NOW())
    </insert>

    <update id="update" parameterType="com.bloger.backend.entity.Tag">
        UPDATE tag
        SET name = #{name}, description = #{description}, sort = #{sort}, update_time = NOW()
        WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM tag WHERE id = #{id}
    </delete>
</mapper>