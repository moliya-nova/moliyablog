<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bloger.backend.mapper.PageMapper">
    <resultMap id="PageResult" type="com.bloger.backend.entity.Page">
        <id column="id" property="id"/>
        <result column="slug" property="slug"/>
        <result column="title" property="title"/>
        <result column="content" property="content"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectById" resultMap="PageResult">
        SELECT * FROM page WHERE id = #{id}
    </select>

    <select id="selectBySlug" resultMap="PageResult">
        SELECT * FROM page WHERE slug = #{slug}
    </select>

    <select id="selectList" resultMap="PageResult">
        SELECT * FROM page
    </select>

    <insert id="insert" parameterType="com.bloger.backend.entity.Page">
        INSERT INTO page (slug, title, content, status, create_time, update_time)
        VALUES (#{slug}, #{title}, #{content}, #{status}, NOW(), NOW())
    </insert>

    <update id="update" parameterType="com.bloger.backend.entity.Page">
        UPDATE page
        SET slug = #{slug}, title = #{title}, content = #{content}, status = #{status}, update_time = NOW()
        WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM page WHERE id = #{id}
    </delete>
</mapper>
